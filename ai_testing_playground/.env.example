# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored — never commit real credentials.

# --- Required ---
APP_BASE_URL=https://your-app-under-test.example.com
APP_USERNAME=your_username
APP_PASSWORD=your_password

# --- Optional: local run behaviour ---
# Show the browser during local runs (tests run headless by default in CI)
APP_HEADLESS=false
# Slow each Playwright action down by N ms so you can watch a visible run
PLAYWRIGHT_SLOW_MO_MS=0
# Settle window (ms) after each test before the browser context closes
POST_TEST_SETTLE_MS=500
# Retry/timeout tuning for navigating back to the app shell
HOME_NAVIGATION_ATTEMPTS=3
HOME_NAVIGATION_TIMEOUT_MS=45000
